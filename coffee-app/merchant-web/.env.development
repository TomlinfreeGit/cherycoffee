# filepath: coffee-app/merchant-web/.env.development
# Used by `npm run dev`. Leave empty to use the Vite proxy (see vite.config.ts),
# which intercepts /api and /uploads and forwards to https://rpi.tomlinfree.dpdns.org.
#
# If you'd rather skip the proxy and call the API directly in dev too, set:
#   VITE_API_BASE=https://rpi.tomlinfree.dpdns.org/api
#   VITE_UPLOADS_BASE=https://rpi.tomlinfree.dpdns.org

VITE_API_BASE=https://rpi.tomlinfree.dpdns.org/api
VITE_UPLOADS_BASE=https://rpi.tomlinfree.dpdns.org
