/* filepath: coffee-app/mini-program/pages/order-list/order-list.wxss */
.page-list {
  padding: 24rpx;
  /* 让里面的 .order-scroll 可以用 height:100% 计算出可用高度 */
  display: flex;
  flex-direction: column;
  /* 页面级使用 100vh,scroll-view 占用剩下空间以便触底 */
  min-height: 100vh;
  box-sizing: border-box;
}

/* scroll-view 填充剩余高度,只有它能滚动 */
.order-scroll {
  flex: 1 1 auto;
  /* 必须给个明确高度才能在微信里触发 scrolltolower; 用 calc 减去顶部卡片 */
  height: calc(100vh - 132rpx); /* 132rpx = 顶卡 (108rpx) + 间距 (24rpx) */
  box-sizing: border-box;
}

.profile-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--panel);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.profile-card:active {
  background: var(--bg);
}

.profile-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-card-icon {
  font-size: 48rpx;
}

.profile-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.profile-card-subtitle {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

.profile-card-arrow {
  font-size: 40rpx;
  color: var(--muted);
  font-weight: 300;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: var(--panel);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.order-card:active {
  background: var(--bg);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-header .pickup-number {
  font-size: 36rpx;
  font-weight: 700;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--muted);
}

.order-meta .total {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

/* 列表底部状态 */
.list-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 32rpx 0 24rpx;
  font-size: 22rpx;
  color: var(--muted);
}
.list-footer .muted {
  color: var(--muted);
}
.footer-spinner {
  font-size: 24rpx;
  display: inline-block;
  animation: spin 1s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
