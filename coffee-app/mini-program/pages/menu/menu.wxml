<!-- filepath: coffee-app/mini-program/pages/menu/menu.wxml -->
<!--
  顶层 .page-menu 改为纵向 flex:
    - .level-bar  顶部 banner (flex: 0 0 auto,仅 level>1 渲染)
    - .menu-body  横向 flex,包含 sidebar + product-area
  这样 banner 会真正占用 56rpx 的高度,下面的 scroll-view
  自动缩短,不会被 banner 遮住顶部菜单内容。
-->
<view class="page-menu">
  <view class="level-bar" wx:if="{{hasDiscount}}">
    <text class="level-icon">⭐</text>
    <text class="level-text">Lv.{{userLevel}} 会员专享价</text>
  </view>

  <view class="menu-body">
  <!-- 左侧分类栏 -->
  <scroll-view class="category-sidebar" scroll-y enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="sidebar-item {{activeCategory === item.name ? 'active' : ''}}"
      data-key="{{item.name}}"
      bindtap="switchCategory"
    >
      <view class="sidebar-icon">{{item.icon || '·'}}</view>
      <view class="sidebar-label">{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- 右侧商品列表 -->
  <scroll-view class="product-area" scroll-y enhanced show-scrollbar="{{false}}">
    <block wx:if="{{loading}}">
      <view class="empty">
        <text class="empty-icon">⏳</text>
        <text>加载中...</text>
      </view>
    </block>

    <block wx:elif="{{categories.length === 0}}">
      <view class="empty">
        <text class="empty-icon">☕</text>
        <text>暂无分类</text>
      </view>
    </block>

    <block wx:else>
      <block wx:for="{{products}}" wx:key="id" wx:if="{{item.category === activeCategory}}">
        <view class="product-card">
          <!-- 可点击的图片:弹出大图详情 -->
          <view
            class="product-image"
            hover-class="image-hover"
            hover-stay-time="100"
            data-id="{{item.id}}"
            bindtap="onProductImageTap"
          >
            <image
              wx:if="{{item.imageUrl}}"
              src="{{item.imageUrl}}"
              class="product-img"
              mode="aspectFill"
              binderror="onImageError"
              data-id="{{item.id}}"
            />
            <text wx:else class="product-emoji">{{item.icon || '☕'}}</text>
            <view class="image-tap-hint">点击查看</view>
          </view>

          <view class="product-info">
            <view class="product-name">{{item.name}}</view>
            <view class="product-desc" wx:if="{{item.description}}">{{item.description}}</view>
            <view class="product-bottom">
              <view class="product-price-line">
                <!--
                  兑底: discounted_price 可能在某些加载路径下未填充
                  (例如商品列表刚拉回来还未走 applyDiscountToProducts)。
                  使用 wx:if 兑底到原始价 item.price,避免出现空白。
                -->
                <text class="product-price price">{{item.discounted_price || item.price}}</text>
                <text class="product-price-original" wx:if="{{item.has_discount}}">¥{{item.price}}</text>
              </view>
              <button
                class="btn btn-primary btn-sm"
                size="mini"
                data-id="{{item.id}}"
                catchtap="addToCart"
              >
                + 加入
              </button>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{activeCategoryEmpty}}">
        <view class="empty">
          <text class="empty-icon">📭</text>
          <text>该分类暂无商品</text>
        </view>
      </block>
    </block>
  </scroll-view>

  <!-- 浮动购物车栏 -->
  <view class="bottom-bar" wx:if="{{cartCount > 0}}" bindtap="goToCart">
    <view class="cart-icon-wrap">
      <text class="cart-icon">🛒</text>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="summary">已选 {{cartCount}} 件</view>
    <view class="total price">{{cartTotal}}</view>
    <view class="btn btn-primary btn-sm">去结算 →</view>
  </view>

  <!-- 商品详情弹窗(从底部弹出) -->
  <view
    wx:if="{{detailVisible}}"
    class="detail-mask"
    bindtap="closeDetail"
    catchtouchmove="noop"
  >
    <view class="detail-sheet" catchtap="noop">
      <view class="detail-image-wrap">
        <image
          wx:if="{{detailProduct.imageUrl}}"
          src="{{detailProduct.imageUrl}}"
          class="detail-image"
          mode="aspectFill"
        />
        <view wx:else class="detail-emoji">{{detailProduct.icon || '☕'}}</view>
        <view class="detail-close" catchtap="closeDetail">✕</view>
      </view>

      <view class="detail-body">
        <view class="detail-name">{{detailProduct.name}}</view>
        <!-- 注意：.price class 会在前面自动加 ¥ (CSS ::before),所以这里不能再写 ¥ -->
        <view class="detail-price-wrap">
          <text class="detail-price price">{{detailProduct.discounted_price || detailProduct.price}}</text>
          <text class="detail-price-original" wx:if="{{detailProduct.has_discount}}">原价 ¥{{detailProduct.price}}</text>
        </view>
        <view class="detail-section-title">商品介绍</view>
        <view class="detail-desc">
          {{detailProduct.description || '暂无介绍'}}
        </view>
      </view>

      <view class="detail-footer">
        <button class="btn btn-primary detail-add-btn" catchtap="addToCartFromDetail">
          + 加入购物车
        </button>
      </view>
    </view>
  </view>
  </view><!-- /.menu-body -->
</view><!-- /.page-menu -->