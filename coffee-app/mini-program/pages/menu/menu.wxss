/* filepath: coffee-app/mini-program/pages/menu/menu.wxss */
.page-menu {
  padding-bottom: 140rpx;
}

/* 分类切换 */
.category-tabs {
  display: flex;
  background: var(--panel);
  padding: 16rpx 24rpx;
  gap: 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid var(--border);
}

.category-tab {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--muted);
  background: var(--bg);
  transition: all 0.15s;
}

.category-tab.active {
  background: var(--primary);
  color: white;
  font-weight: 500;
}

/* 商品列表 */
.product-list {
  padding: 24rpx;
}

.product-card {
  display: flex;
  background: var(--panel);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.product-image {
  width: 140rpx;
  height: 140rpx;
  background: var(--bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.product-img {
  width: 140rpx;
  height: 140rpx;
  display: block;
}

.product-emoji {
  font-size: 72rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: 700;
}

/* 浮动购物车栏 */
.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: var(--danger);
  color: white;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.summary {
  flex: 1;
  font-size: 24rpx;
  color: var(--muted);
  margin-left: 16rpx;
}

.total {
  font-size: 36rpx;
  font-weight: 700;
}
