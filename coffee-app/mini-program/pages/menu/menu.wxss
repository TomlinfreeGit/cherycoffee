/* filepath: coffee-app/mini-program/pages/menu/menu.wxss */
/* ============================================================================
 * IMPORTANT — 微信小程序布局说明
 * ----------------------------------------------------------------------------
 * 微信里 `page` 元素的默认高度等于"窗口内容区",而 tabBar 是叠在页面下方的,
 * `100vh` 在小程序里通常指"可视窗口高度"而非"页面可用高度"。
 *
 * 因此我们使用 `position: absolute; inset: 0` 让 .page-menu 自动填满
 * WeChat 框架给我们的页面区域,然后用 flex 把两个滚动区按比例分配剩余空间。
 *
 * 浮动购物车栏 .bottom-bar 用 `position: absolute` 叠在底部,这样不会从
 * 文档流里"挤掉"任何空间——左右两个 scroll-view 高度仍然能占满。
 * ============================================================================ */

.page-menu {
  position: absolute;
  inset: 0;
  /* 纵向 flex: banner 在上,下面 menu-body 占满剩余空间 */
  display: flex;
  flex-direction: column;
  background: var(--bg);
  overflow: hidden;
}

/* ─── 顶部会员等级条 ──────────────────────────────── */
/* 作为 flex 子项,固定高度 56rpx,不再 absolute 覆上去 */
.level-bar {
  flex: 0 0 56rpx;
  background: linear-gradient(90deg, #ff9966, #ff5e62);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
.level-bar .level-icon { margin-right: 8rpx; }

/* 横向下半区:左 sidebar + 右 product-area */
.menu-body {
  flex: 1 1 auto;
  display: flex;
  flex-direction: row;
  min-height: 0; /* 重要:让 flex 子项能在一级 flex 容器中缩到比内容小 */
  overflow: hidden;
}

/* ─── 左侧分类栏 ─────────────────────────────────── */
.category-sidebar {
  /* Fixed width sidebar — scroll-view 内部高度由父元素撑开 */
  width: 200rpx;
  flex: 0 0 200rpx;
  background: var(--panel);
  border-right: 1rpx solid var(--border);
  /* 关键:scroll-view 需要确定高度才能滚动。
     在 flex 容器里 用 height:100% + flex 自身拉伸 填满 .menu-body 剩余高度 */
  height: 100%;
  /* flex 子项想要被压到比内容小,必须显式声明 */
  min-height: 0;
}

/*
 * 侧边栏条目 —— 双语显示（中文上，英文下），不再渲染 emoji 图标。
 * 与设计参考图保持一致:左 4rpx 强调色竖条作为激活态指示,无图标,
 * 上下结构:中文 28rpx (主色) + 英文 22rpx (浅色)。
 */
.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  position: relative;
  border-left: 4rpx solid transparent;
  transition: all 0.15s;
  /* 允许长英文名换行,避免横向溢出 200rpx 容器 */
  overflow: hidden;
}

.sidebar-item.active {
  background: var(--bg);
  border-left-color: var(--primary);
}

.sidebar-name-zh {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.3;
  text-align: center;
  font-weight: 500;
  /* 长名称支持换行 */
  word-break: break-all;
  max-width: 100%;
}

.sidebar-name-en {
  font-size: 22rpx;
  color: var(--muted);
  line-height: 1.3;
  margin-top: 4rpx;
  text-align: center;
  /* 英文允许在词内断行,避免 200rpx 容器溢出 */
  word-break: break-all;
  max-width: 100%;
}

.sidebar-item.active .sidebar-name-zh {
  color: var(--primary);
  font-weight: 600;
}

.sidebar-item.active .sidebar-name-en {
  color: var(--primary);
  opacity: 0.75;
}

/* ─── 右侧商品列表 ─────────────────────────────────── */
.product-area {
  /* 占据除左侧 200rpx 外的全部空间 */
  flex: 1;
  width: calc(100% - 200rpx);
  height: 100%;
  min-height: 0;
  padding: 16rpx 16rpx 24rpx;
  box-sizing: border-box;
}

.product-card {
  display: flex;
  background: var(--panel);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 可点击的图片 */
.product-image {
  width: 160rpx;
  height: 160rpx;
  background: var(--bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  display: block;
}

.product-emoji {
  font-size: 80rpx;
}

.image-tap-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 4rpx 0;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 18rpx;
  text-align: center;
  opacity: 0;
  transition: opacity 0.15s;
}

.product-image:active .image-tap-hint,
.image-hover .image-tap-hint {
  opacity: 1;
}

.image-hover {
  opacity: 0.85;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  /* 当价格超长时优先压缩价格行，按钮保持原宽不変形 */
  gap: 12rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: 700;
}

/* 价格行:支持折扣后价格 + 划线原价。
   重点:不要设 overflow:hidden,否则划线原价会被裁掉。
   价格行自然撑开,按钮靠 flex:0 0 auto 锁定宽度不拉伸即可。 */
.product-price-line {
  display: flex;
  align-items: baseline;
  margin-right: 16rpx;
  /* 允许子项超出该行自然宽度,即使超过 .product-info 的可用空间 */
  flex: 1 1 auto;
  min-width: 0;
}
/* 按钮容器:固定为小尺寸,不被 flex 拉伸 */
.product-bottom .btn {
  /* 覆盖全局 .btn 的 padding,让按钮紧一点 */
  padding: 6rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.4;
  /* 锁定宽度,避免被 flex 拉伸或压缩 */
  flex: 0 0 auto;
  width: 120rpx;
  text-align: center;
  white-space: nowrap;
}
.product-price-original {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 8rpx;
  /* 保持原文本完整,不裁剪 */
  flex-shrink: 0;
  white-space: nowrap;
}
.detail-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex-wrap: wrap;
}
.detail-price-original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

/* ─── 空状态 ─────────────────────────────────── */
.empty {
  padding: 80rpx 40rpx;
  text-align: center;
  color: var(--muted);
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

/* ─── 浮动购物车栏 ─────────────────────────────────── */
/* 用 absolute 定位让它浮在底部,不会把内容挤下去 */
.bottom-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  background: var(--panel);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: var(--danger);
  color: white;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.summary {
  flex: 1;
  font-size: 24rpx;
  color: var(--muted);
}

.total {
  font-size: 36rpx;
  font-weight: 700;
}

/* ─── 商品详情弹窗 ─────────────────────────────────── */
.detail-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-sheet {
  width: 100%;
  background: var(--panel);
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 80%;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-image-wrap {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 480rpx;
}

.detail-emoji {
  font-size: 200rpx;
}

.detail-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-body {
  padding: 32rpx 32rpx 16rpx;
  flex: 1;
  overflow-y: auto;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.detail-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 24rpx;
}

.detail-section-title {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.detail-desc {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-footer {
  padding: 16rpx 32rpx 32rpx;
  border-top: 1rpx solid var(--border);
}

.detail-add-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-add-btn::after {
  border: none;
}