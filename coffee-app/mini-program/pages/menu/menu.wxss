/* filepath: coffee-app/mini-program/pages/menu/menu.wxss */
.page-menu {
  display: flex;
  height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ─── 左侧分类栏 ─────────────────────────────────── */
.category-sidebar {
  width: 200rpx;
  height: 100%;
  background: var(--panel);
  border-right: 1rpx solid var(--border);
  flex-shrink: 0;
}

.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  position: relative;
  border-left: 6rpx solid transparent;
  transition: all 0.15s;
}

.sidebar-item.active {
  background: var(--bg);
  border-left-color: var(--primary);
  font-weight: 600;
}

.sidebar-item.active .sidebar-label {
  color: var(--primary);
}

.sidebar-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
  line-height: 1;
}

.sidebar-label {
  font-size: 26rpx;
  color: var(--text);
  text-align: center;
}

/* ─── 右侧商品列表 ─────────────────────────────────── */
.product-area {
  flex: 1;
  height: 100%;
  padding: 16rpx;
  box-sizing: border-box;
}

.product-card {
  display: flex;
  background: var(--panel);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 可点击的图片 */
.product-image {
  width: 160rpx;
  height: 160rpx;
  background: var(--bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  display: block;
}

.product-emoji {
  font-size: 80rpx;
}

.image-tap-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 4rpx 0;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 18rpx;
  text-align: center;
  opacity: 0;
  transition: opacity 0.15s;
}

.product-image:active .image-tap-hint,
.image-hover .image-tap-hint {
  opacity: 1;
}

.image-hover {
  opacity: 0.85;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: 700;
}

/* ─── 空状态 ─────────────────────────────────── */
.empty {
  padding: 80rpx 40rpx;
  text-align: center;
  color: var(--muted);
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

/* ─── 浮动购物车栏 ─────────────────────────────────── */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  background: var(--panel);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: var(--danger);
  color: white;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.summary {
  flex: 1;
  font-size: 24rpx;
  color: var(--muted);
}

.total {
  font-size: 36rpx;
  font-weight: 700;
}

/* ─── 商品详情弹窗 ─────────────────────────────────── */
.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-sheet {
  width: 100%;
  background: var(--panel);
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-image-wrap {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 480rpx;
}

.detail-emoji {
  font-size: 200rpx;
}

.detail-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-body {
  padding: 32rpx 32rpx 16rpx;
  flex: 1;
  overflow-y: auto;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.detail-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 24rpx;
}

.detail-section-title {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.detail-desc {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-footer {
  padding: 16rpx 32rpx 32rpx;
  border-top: 1rpx solid var(--border);
}

.detail-add-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-add-btn::after {
  border: none;
}