/* filepath: coffee-app/mini-program/pages/order-detail/order-detail.wxss */
.page-detail {
  padding: 24rpx;
}

.pickup-section {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
  border-radius: 20rpx;
  padding: 48rpx 24rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(111, 78, 55, 0.25);
}

.pickup-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-bottom: 16rpx;
}

.pickup-number {
  font-size: 80rpx;
  font-weight: 700;
  color: white;
  letter-spacing: 0.05em;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: var(--muted);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.item-thumb {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.item-img {
  width: 80rpx;
  height: 80rpx;
  display: block;
}

.item-emoji {
  font-size: 40rpx;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  min-width: 0;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty {
  color: var(--muted);
  font-size: 24rpx;
}

.item-price {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 100rpx;
  text-align: right;
}

.total-row {
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
  margin-top: 12rpx;
  font-weight: 600;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
}

.tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 152, 0, 0.1);
  color: var(--warning);
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-top: 24rpx;
}

/* 底部操作栏: 立即支付 / 取消订单 (仅 pending 状态显示) */
.bottom-bar-placeholder {
  height: 140rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid var(--border);
  z-index: 10;
}

.bottom-bar .btn {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}

.bottom-bar .btn-primary {
  flex: 1.6;
}

button[disabled].btn-primary {
  opacity: 0.6;
}

