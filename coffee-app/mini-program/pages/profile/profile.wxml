<!-- filepath: coffee-app/mini-program/pages/profile/profile.wxml -->
<view class="page-profile">
  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>

  <block wx:else>
    <!-- 会员等级卡片 -->
    <view class="level-card">
      <view class="level-card-header">
        <view class="level-badge">Lv.{{userLevel}}</view>
        <!--
          Lv.1 时 discount = 1.00 意味着全价不打折,显示 “无折扣” 更友好。
          高级别才显示 99折 / 95折 这种折扣幅度。
        -->
        <view class="level-discount" wx:if="{{discountPct >= 100}}">无折扣</view>
        <view class="level-discount" wx:else>{{discountPct}}折</view>
      </view>
      <view class="level-progress-label">
        <text>已完成 {{completedOrders}} 单</text>
        <text wx:if="{{userLevel < 999}}">还差 {{nextLevelOrders}} 单升级</text>
      </view>
      <view class="level-progress-track">
        <view class="level-progress-fill" style="width: {{levelProgress}}%"></view>
      </view>
      <view class="level-progress-foot">
        <text>{{userLevel === 1 ? 0 : (userLevel - 1) * nextLevelThreshold}}</text>
        <text>Lv.{{userLevel + 1}}</text>
      </view>
    </view>

    <!-- 昵称区域 -->
    <view class="section">
      <view class="section-title">昵称</view>
      <view class="nickname-row">
        <input
          type="nickname"
          class="nickname-input"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameBlur"
          bindconfirm="onNicknameBlur"
          placeholder="点击输入您的昵称"
          maxlength="30"
        />
      </view>
      <view class="hint">输入后点空白处自动保存</view>
    </view>

    <!-- 手机号区域 -->
    <view class="section">
      <view class="section-title">手机号</view>

      <block wx:if="{{hasPhone}}">
        <view class="phone-display">
          <text class="phone-masked">{{phoneMasked}}</text>
          <text class="phone-status">已绑定</text>
        </view>
        <button class="btn btn-secondary" bindtap="unbindPhone">解绑手机号</button>
      </block>

      <block wx:else>
        <view class="hint phone-empty">尚未绑定手机号，取餐时无法联系您</view>

        <!-- 主按钮：微信一键授权 -->
        <button
          class="btn btn-primary phone-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
          bindtap="onPhoneBtnTap"
        >
        一键获取手机号
        </button>

        <!-- 折叠的手动输入（开发 / 模拟器 / 微信拒绝时使用） -->
        <view class="manual-toggle" bindtap="toggleManual">
          <text>{{manualOpen ? '收起' : '手动输入手机号'}}</text>
        </view>

        <block wx:if="{{manualOpen}}">
          <view class="manual-row">
            <input
              type="number"
              class="manual-input"
              value="{{manualPhone}}"
              bindinput="onManualPhoneInput"
              placeholder="11 位手机号"
              maxlength="11"
            />
            <button
              class="btn btn-secondary manual-save"
              bindtap="onManualSave"
              disabled="{{saving}}"
            >保存</button>
          </view>
        </block>
      </block>
    </view>

    <view class="footer-hint">
      · 昵称保存到云端，登录后自动恢复<br/>
      · 手机号仅用于取餐联系<br/>
      · 取餐号会显示在「我的订单」页面
    </view>
  </block>
</view>
