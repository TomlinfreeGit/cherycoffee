/* filepath: coffee-app/mini-program/pages/profile/profile.wxss */
.page-profile {
  padding: 24rpx;
  padding-bottom: 80rpx;
}

.loading {
  text-align: center;
  color: var(--muted);
  padding: 80rpx 0;
}

.section {
  background: var(--panel);
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 24rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--bg);
  padding: 0;
  margin: 0;
  line-height: normal;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 24rpx;
  color: var(--muted);
  text-align: center;
}

.hint {
  font-size: 22rpx;
  color: var(--muted);
  flex: 1;
}

.nickname-row {
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.nickname-input {
  height: 80rpx;
  font-size: 28rpx;
  color: var(--text);
}

.phone-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.phone-masked {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  letter-spacing: 1rpx;
}

.phone-status {
  font-size: 22rpx;
  color: #16a34a;
  background: rgba(22, 163, 74, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.phone-empty {
  display: block;
  text-align: center;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.phone-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 999rpx;
}

.btn {
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-secondary {
  background: var(--bg);
  color: var(--text);
  border: 2rpx solid var(--border);
}

.footer-hint {
  margin-top: 40rpx;
  padding: 24rpx 32rpx;
  font-size: 22rpx;
  color: var(--muted);
  line-height: 1.8;
  text-align: center;
}
