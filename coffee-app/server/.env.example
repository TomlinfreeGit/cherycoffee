# filepath: coffee-app/server/.env.example
# Copy to .env and fill in your values

# Server port
PORT=3000

# Server host:
#   0.0.0.0 - listen on all interfaces (recommended for real-device testing)
#   127.0.0.1 - localhost only (more secure, but not reachable from phone)
HOST=0.0.0.0

# Database file location (relative to server/ directory)
DB_PATH=./data/coffee.db

# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGIN=http://localhost:5173

# ─── WeChat Mini-Program Auth ────────────────────────────
# Get these from https://mp.weixin.qq.com → 开发管理 → 开发设置
# AppID is public (in project.config.json too). AppSecret is private.
WECHAT_APPID=wx1234567890abcdef
WECHAT_SECRET=your_app_secret_here_replace_me

# When true (default), use real WeChat code2session API.
# When false, generate a mock openid from the code (for local dev without credentials).
USE_REAL_WECHAT_AUTH=true

# If USE_REAL_WECHAT_AUTH=true but api.weixin.qq.com is unreachable
# (DNS/timeout/firewall), automatically fall back to mock mode so local dev
# keeps working. A warning is logged. Set to 'false' to disable the fallback
# and surface the real network error instead.
WECHAT_FALLBACK_TO_MOCK=true

# ─── WeChat Pay V3 ─────────────────────────────────────
# 商户平台 (https://pay.weixin.qq.com) 申请开通"小程序支付"或"JSAPI 支付"
# 在"开发配置"里设置回调 URL: https://你的域名/api/orders/pay/notify  (必须 HTTPS)
# APIv3 密钥 在「账户中心 / API安全」生成 (32 位)
# 商户证书 在「账户中心 / API安全 / API证书」下载,得到 apiclient_cert.pem / apiclient_key.pem
# 同时在「API安全 / APIv3 密钥 / 微信支付公钥」下载 pub_key.pem,用于回调验签

WECHAT_MCH_ID=
WECHAT_API_V3_KEY=                                # 32 位 V3 密钥
WECHAT_NOTIFY_URL=                                # 公网可访问的回调地址,例如 https://yourdomain.com/api/orders/pay/notify
WECHAT_SERIAL_NO=                                 # 商户证书序列号 (商户后台证书页可见)
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem # 商户私钥
WECHAT_PAY_PUBLIC_KEY_PATH=./certs/pub_key.pem    # 微信支付公钥 (回调验签用)

# ★ 商户凭据未全部配置时,后端会自动 fallback 到 MOCK 模式,前端弹窗模拟支付成功。
#   这样本地开发无商户号也能跑通全流程。
